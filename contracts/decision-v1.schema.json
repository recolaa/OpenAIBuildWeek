{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentbridge.local/contracts/decision-v1.schema.json",
  "title": "IntentBridge chat-agent decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "request_id",
    "event_id",
    "incident_id",
    "incident_version",
    "decision",
    "justification",
    "issued_at"
  ],
  "properties": {
    "schema_version": {
      "const": "decision-v1"
    },
    "decision_id": {
      "$ref": "#/$defs/identifier"
    },
    "request_id": {
      "$ref": "#/$defs/identifier"
    },
    "event_id": {
      "$ref": "#/$defs/identifier"
    },
    "incident_id": {
      "$ref": "#/$defs/identifier"
    },
    "incident_version": {
      "type": "integer",
      "minimum": 1
    },
    "decision": {
      "$ref": "#/$defs/decision"
    },
    "grant_scope": {
      "anyOf": [
        {
          "$ref": "#/$defs/flow_scope"
        },
        {
          "type": "null"
        }
      ]
    },
    "ttl_seconds": {
      "anyOf": [
        {
          "$ref": "#/$defs/ttl"
        },
        {
          "type": "null"
        }
      ]
    },
    "approved_by": {
      "anyOf": [
        {
          "$ref": "#/$defs/approver"
        },
        {
          "type": "null"
        }
      ]
    },
    "justification": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "enum": ["ALLOW_TEMPORARY", "BLOCK_TEMPORARY"]
          }
        },
        "required": ["decision"]
      },
      "then": {
        "required": ["grant_scope", "ttl_seconds", "approved_by"],
        "properties": {
          "grant_scope": {
            "$ref": "#/$defs/flow_scope"
          },
          "ttl_seconds": {
            "$ref": "#/$defs/ttl"
          },
          "approved_by": {
            "$ref": "#/$defs/approver"
          }
        }
      },
      "else": {
        "properties": {
          "grant_scope": {
            "type": "null"
          },
          "ttl_seconds": {
            "type": "null"
          }
        }
      }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{0,127}$"
    },
    "ip_address": {
      "type": "string",
      "anyOf": [
        {
          "format": "ipv4"
        },
        {
          "format": "ipv6"
        }
      ],
      "not": {
        "pattern": "[/*%]"
      }
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "ttl": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400
    },
    "decision": {
      "enum": [
        "ALLOW_TEMPORARY",
        "BLOCK_TEMPORARY",
        "KEEP_CURRENT_POLICY",
        "DENY",
        "REQUEST_MORE_INFORMATION"
      ]
    },
    "flow_scope": {
      "type": "object",
      "additionalProperties": false,
      "dependentRequired": {
        "interface_in": ["interface_out"],
        "interface_out": ["interface_in"]
      },
      "required": [
        "source_ip",
        "destination_ip",
        "destination_port",
        "protocol"
      ],
      "properties": {
        "source_ip": {
          "$ref": "#/$defs/ip_address"
        },
        "destination_ip": {
          "$ref": "#/$defs/ip_address"
        },
        "destination_port": {
          "$ref": "#/$defs/port"
        },
        "protocol": {
          "enum": ["tcp", "udp"]
        },
        "direction": {
          "const": "forward",
          "default": "forward"
        },
        "interface_in": {
          "anyOf": [
            {
              "$ref": "#/$defs/interface_name"
            },
            {
              "type": "null"
            }
          ]
        },
        "interface_out": {
          "anyOf": [
            {
              "$ref": "#/$defs/interface_name"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "interface_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,63}$"
    },
    "approver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    }
  }
}
