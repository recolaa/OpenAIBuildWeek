{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentbridge.local/contracts/network-event-v1.schema.json",
  "title": "IntentBridge normalized network event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "timestamp",
    "source",
    "event_type",
    "flow",
    "reason"
  ],
  "properties": {
    "schema_version": {
      "const": "network-event-v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{0,127}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "enum": ["firewall", "zeek", "ids", "generic", "manual"]
    },
    "event_type": {
      "enum": [
        "FIREWALL_DROP",
        "CONNECTION",
        "DNS",
        "HTTP",
        "TLS",
        "NOTICE",
        "ALERT",
        "POLICY_CHANGE",
        "OTHER"
      ]
    },
    "flow": {
      "$ref": "#/$defs/network_flow"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "policy_metadata": {
      "$ref": "#/$defs/policy_metadata"
    },
    "severity": {
      "enum": ["info", "low", "medium", "high", "critical"],
      "default": "medium"
    },
    "raw_context": {
      "type": "object",
      "maxProperties": 512,
      "additionalProperties": true,
      "$comment": "The application additionally enforces the bounded JSON evidence limits."
    }
  },
  "$defs": {
    "ip_address": {
      "type": "string",
      "anyOf": [
        {
          "format": "ipv4"
        },
        {
          "format": "ipv6"
        }
      ],
      "not": {
        "pattern": "[/*%]"
      }
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "network_flow": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_ip": {
          "$ref": "#/$defs/ip_address"
        },
        "destination_ip": {
          "$ref": "#/$defs/ip_address"
        },
        "source_port": {
          "$ref": "#/$defs/port"
        },
        "destination_port": {
          "$ref": "#/$defs/port"
        },
        "protocol": {
          "enum": ["tcp", "udp", "icmp", "other"],
          "default": "other"
        },
        "direction": {
          "enum": ["input", "output", "forward", "unknown"],
          "default": "unknown"
        },
        "interface_in": {
          "anyOf": [
            {
              "$ref": "#/$defs/interface_name"
            },
            {
              "type": "null"
            }
          ]
        },
        "interface_out": {
          "anyOf": [
            {
              "$ref": "#/$defs/interface_name"
            },
            {
              "type": "null"
            }
          ]
        },
        "packet_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9223372036854775807
        },
        "byte_count": {
          "type": "integer",
          "minimum": 0
        },
        "community_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      }
    },
    "policy_metadata": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{0,127}$"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "action": {
          "enum": ["ALLOW", "BLOCK"]
        },
        "risk_level": {
          "enum": ["info", "low", "medium", "high", "critical"]
        },
        "maximum_ttl_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "requires_human_context": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      }
    },
    "interface_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,63}$"
    }
  }
}
