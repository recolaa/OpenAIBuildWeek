# Copy these names into .env. Never commit the real key.
OPENAI_API_KEY=
REASONER_MODE=openai
OPENAI_MODEL=gpt-4.1-mini
ALLOW_NON_BUDGET_MODEL=false
LLM_MAX_OUTPUT_TOKENS=800
MAX_CONCURRENT_ANALYSES=2
ANALYSIS_QUEUE_TIMEOUT_SECONDS=2

# The unfinished teammate services are represented by safe adapters.
CHAT_MODE=outbox
CHAT_AGENT_URL=
CHAT_AGENT_TOKEN=
# Optional single-token local-demo compatibility. Real mode requires the two distinct tokens.
INTEGRATION_API_TOKEN=
NETWORK_INGEST_TOKEN=
CHAT_INTEGRATION_TOKEN=
TRUSTED_CHAT_AGENT_ID=chat-agent
TRUSTED_CHAT_AGENT_ROLE=network-manager
FIREWALL_MODE=in_memory
FIREWALL_ENABLED=false
ALLOW_HOST_FIREWALL=false

DEMO_MODE=true
MAX_TTL_SECONDS=600
DEFAULT_TTL_SECONDS=60
CONTEXT_REQUEST_TIMEOUT_SECONDS=120
MAX_CONTEXT_ROUNDS=3
DECISION_CLOCK_SKEW_SECONDS=30
DEDUP_WINDOW_SECONDS=30
EXPIRY_POLL_SECONDS=1
