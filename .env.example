# Copy this file to .env and replace placeholder values.
OPENAI_API_KEY=change-this
OPENAI_MODEL=gpt-5.6-luna

# Used by the Streamlit UI.
BACKEND_URL=http://localhost:8003

# Local SQLite file used for durable chat and security-event history.
DATABASE_PATH=chat_history.db

# Receives the summarized, idempotent human-response callback.
COORDINATOR_RESPONSE_URL=http://localhost:8004/human-responses
